# Configuration for Edge Device Detector

# Backend API Configuration
API_URL="http://localhost:8000"  # Change to VPS public IP
DEVICE_ID="pi-001"
DEVICE_NAME="Raspberry Pi - Front Door"

# Camera Configuration
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Model Configuration
MODEL_SIZE="yolov5n"  # Options: yolov5n, yolov5s, yolov5m, yolov5l, yolov5x
CONFIDENCE_THRESHOLD=0.45
TRACKING_DISTANCE=50

# Performance Control
USE_CPU=true  # Set to false if GPU available
MAX_THREADS=4

# Upload Configuration
UPLOAD_ENABLED=true
UPLOAD_INTERVAL=1  # Seconds between detection uploads

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
LOG_FILE="/var/log/eyes-detector.log"

# Device Location (Optional)
LATITUDE="0.0"
LONGITUDE="0.0"
